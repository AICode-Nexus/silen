{
  "name": "@aicode-nexus/silen",
  "version": "0.1.3",
  "description": "A lightweight documentation-first static site generator powered by React, TypeScript, Vite, and MDX.",
  "keywords": [
    "documentation",
    "static-site-generator",
    "react",
    "vite",
    "mdx"
  ],
  "homepage": "https://aicode-nexus.github.io/silen/",
  "bugs": {
    "url": "https://github.com/AICode-Nexus/silen/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AICode-Nexus/silen.git"
  },
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "pnpm@10.34.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "bin": {
    "silen": "dist/node/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./theme": {
      "types": "./dist/theme-default/index.d.ts",
      "import": "./dist/theme-default/index.js"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js"
    },
    "./agent/*": "./dist/agent/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && jiti tooling/build-agent-contract.ts",
    "site:build": "pnpm build && node dist/node/cli.js build website",
    "site:dev": "pnpm build && node dist/node/cli.js dev website",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@mdx-js/mdx": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@mdx-js/rollup": "3.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tailwindcss/vite": "4.3.2",
    "@vitejs/plugin-react": "6.0.3",
    "cac": "7.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "esbuild": "0.28.1",
    "fast-glob": "3.3.3",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.3",
    "lucide-react": "1.24.0",
    "mdast-util-to-markdown": "2.1.2",
    "minisearch": "7.2.0",
    "radix-ui": "1.6.2",
    "remark-frontmatter": "5.0.0",
    "remark-mdx-frontmatter": "5.2.0",
    "remark-parse": "11.0.0",
    "remark-stringify": "11.0.0",
    "shiki": "4.3.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "vite": "8.1.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "execa": "9.6.1",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsup": "8.5.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
